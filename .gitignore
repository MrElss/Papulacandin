__pycache__/
# phase6 self-test scratch (regenerated on every run, not real QM data)
analysis/outputs/_selftest_*
# phase7 known-set MMFF ensembles: deterministically regenerable from
# phase7_retrospective_qm.py (fixed seed); results captured in the CSVs
analysis/outputs/qm_runs_known_rdkit/
# NOTE: qm_runs/*_gfn2/ finalist re-rank folders ARE tracked (input pool +
# run_gfn2_rerank.sbatch + the GFN2 results crest_ensemble.xyz / crest_best.xyz
# / rerank.log). Only CREST scratch in those folders is ignored:
analysis/outputs/qm_runs/*_gfn2/pool_gfnff.xyz
analysis/outputs/qm_runs/*_gfn2/crest.restart
analysis/outputs/qm_runs/*_gfn2/crestopt.log
analysis/outputs/qm_runs/*_gfn2/*.out
# Phase 9 xtb namespace scratch (keep *.out results, *.charges, inputs, sbatch)
analysis/outputs/qm_runs_known_xtb/**/*.xtbtopo.mol
analysis/outputs/qm_runs_known_xtb/**/*.xtbrestart
analysis/outputs/qm_runs_known_xtb/**/*.wbo
analysis/outputs/qm_runs_known_xtb/xtb_elec.*.out
analysis/outputs/qm_runs_known_xtb/xtb_elec.*.err
# Phase 10 docking: bulky regenerable artifacts (receptor/ligand pdbqt, raw PDB)
analysis/outputs/phase10_docking/1AO6.pdb
analysis/outputs/phase10_docking/hsa_chainA.pdb
analysis/outputs/phase10_docking/hsa_receptor.pdbqt
analysis/outputs/phase10_docking/ligands/
analysis/outputs/phase10_docking/*.log
analysis/outputs/phase10_docking/test_*.pdbqt
analysis/outputs/deck_assets/
